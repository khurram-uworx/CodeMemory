{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    // Connection String for RepoRegistry sqlite provider (defaults to ./codememory-registry.db)
    "Sqlite": "Data Source=App_Data/registry.db",
    // Connection String for pgvector Storage:Provider
    "PgVector": "Host=..",
    // Connection String for sqlserver Storage:Provider
    "SqlServer": "Server=.."
  },
  "Storage": {
    // [inmemory | sqlite | pgvector | sqlserver]
    "Provider": "inmemory"
  },
  "RepoRegistry": {
    "Provider": "sqlite",
    "CloneBasePath": "./cloned-repos",
    "CloneTimeoutSeconds": 300
  }
}
