{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // Example Connection String for pgvector Storage:Provider
    "PgVector": "Host=localhost;Port=5432;Database=codememory;Username=codememory;Password=codememory",
    // Example Connection String for sqlserver Storage:Provider
    "SqlServer": "Server=localhost;Database=codememory;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Storage": {
    "Provider": "inmemory", // [sqlite | pgvector | sqlserver | inmemory]

    // CodeMemory PgVector Provider configs (WIP)
    "PgVector": {
      "Schema": "public",
      "Index": {
        "Enabled": true,
        "Method": "hnsw",
        "DistanceFunction": "vector_cosine_ops",
        "M": 16,
        "EfConstruction": 64
      }
    }
  },
  "Repositories": {
    "codememory": "..\\..\\",
    "memori": "..\\..\\..\\memori"
  }
}
